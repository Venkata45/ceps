# ── Server Port ────────────────────────────────────────────────────
PORT=5001

# ── MongoDB Atlas Connection String ────────────────────────────────
# Get this from: https://cloud.mongodb.com
#   → Your Cluster → Connect → Drivers → Copy the URI
#   Replace <username>, <password>, and <dbname> with your actual values
MONGO_URI=mongodb+srv://231fa04e20_db_user:sunny15052005@cluster0.9eniqrz.mongodb.net/ceps?retryWrites=true&w=majority&appName=Cluster0

# ── JWT Secret ─────────────────────────────────────────────────────
# Any long random string — used to sign auth tokens
JWT_SECRET=ceps_super_secret_jwt_key_change_this

# ── Admin Credentials ──────────────────────────────────────────────
# These are the hardcoded admin login credentials
ADMIN_EMAIL=admin@ceps.edu
ADMIN_PASSWORD=Admin@123

# ── Gmail / Nodemailer (for OTP & Reset emails) ────────────────────
# Use a Gmail account for sending emails
# EMAIL_PASSWORD must be a Gmail App Password (NOT your real Gmail password)
# Generate one at: https://myaccount.google.com/apppasswords
#   → Enable 2-Step Verification first, then create an App Password
